---
import Logo from "@/components/logos/Logo.astro";
import ThemeButton from "@/components/ThemeButton.astro";

const currentPath = Astro.url.pathname;
---

<header
    class="flex items-center justify-between
px-3 fixed z-100 top-3 left-0 right-0 bg-black/20
backdrop-blur-md h-15 max-w-9/10 rounded-xl w-sm md:w-3xl xl:w-5xl mx-auto"
>
    <Logo />
    <ThemeButton />
</header>
