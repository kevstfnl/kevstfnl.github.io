---
import Avatar from "@/components/logos/Avatar.astro";
---

<section
    class="flex gap-5 px-5 flex-col-reverse h-screen md:flex-row items-center justify-center md:justify-between"
>
    <article class="flex flex-col justify-center gap-10 md:h-full w-full">
        <h1 class="text-4xl md:text-7xl font-black">
            Développeur <br />
            <strong class="text-primary-light">FullStack</strong>
        </h1>
        <p class="text-xl text-text-secondary">
            Je crée des expériences web modernes, performantes et accessibles. <br
            />
            Passionné par les nouvelles technologies et l'innovation.
        </p>
        <nav class="mt-5">
            <ul
                class="flex gap-3 flex-col md:flex-row justify-center md:justify-start"
            >
                <li>
                    <a href="/contact" class="btn btn-primary">Me contacter</a>
                </li>
                <li>
                    <a href="/projects" class="btn btn-secondary"
                        >Voir mes projet</a
                    >
                </li>
            </ul>
        </nav>
    </article>
    <article class="grid place-items-center h-100 w-full md:h-full">
        <Avatar />
    </article>
</section>
