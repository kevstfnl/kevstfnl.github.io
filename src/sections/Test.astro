---
const cards = [
  {
    id: "frontend",
    icon: "🎨",
    title: "Frontend",
    description:
      "Interfaces modernes, accessibles et réactives, avec un soin particulier sur les micro-interactions.",
    technologies: [
      { name: "React" },
      { name: "SolidJS" },
      { name: "TailwindCSS" },
      { name: "Sass" },
    ],
    layout: "md:col-span-3 md:row-span-2",
  },
  {
    id: "backend",
    icon: "🧩",
    title: "Backend",
    description:
      "APIs claires, logiques métier propres et architectures pensées pour durer.",
    technologies: [
      { name: "JavaScript (Node)" },
      { name: "TypeScript (Node/Bun)" },
      { name: "Java" },
      { name: "PHP" },
    ],
    layout: "md:col-span-3",
  },
  {
    id: "fullstack",
    icon: "🧱",
    title: "Fullstack",
    description:
      "De la page au serveur, une approche produit pour garder une vue d’ensemble.",
    technologies: [
      { name: "Next.js" },
      { name: "SolidStart" },
      { name: "Astro" },
    ],
    layout: "md:col-span-3",
  },
  {
    id: "devops",
    icon: "⚙️",
    title: "DevOps",
    description:
      "Automatisation, CI/CD et conteneurs pour des déploiements fiables.",
    technologies: [
      { name: "Docker" },
      { name: "GitHub Workflows" },
    ],
    layout: "md:col-span-3",
  },
  {
    id: "ia",
    icon: "🧠",
    title: "IA & Outillage",
    description:
      "Intégration d’IA, RAG, et outils pour augmenter la productivité et la valeur métier.",
    technologies: [
      { name: "Ollama" },
      { name: "OpenAI" },
      { name: "Anthropic" },
      { name: "RAG" },
      { name: "MCP" },
    ],
    layout: "md:col-span-3",
  },
];
---

<section
  aria-label="Stack technique et expertises"
  class="relative mx-auto max-w-6xl px-4 py-16 md:px-6 lg:px-8"
>
  <div
    class="grid grid-cols-1 gap-5 md:auto-rows-[minmax(190px,auto)] md:grid-cols-6"
  >
    {/* Titre + description dans le bento, sans card */}
    <div class="md:col-span-3 md:row-span-2 flex flex-col justify-between gap-8">
      <div class="space-y-4">
        <h2 class="section-title text-5xl font-bold tracking-tight text-[var(--text-primary)]">
          Stack &amp; expertises
        </h2>
        <p class="text-lg leading-relaxed text-[var(--text-secondary)]">
          Un aperçu rapide de mon terrain de jeu : frontend, backend, fullstack,
          DevOps et IA, le tout pensé pour des produits concrets.
        </p>
      </div>
      <p class="text-sm text-[var(--text-secondary)]">
        Survoler les cartes pour découvrir les stacks et les outils que j’utilise au
        quotidien.
      </p>
    </div>

    {/* Cards techniques */}
    {cards.map((card) => (
      <article
        data-bento-card={card.id}
        class={`group relative overflow-hidden rounded-3xl border border-[var(--border)] bg-[var(--background-secondary)] transition-[background,border-color,box-shadow] duration-300 ${card.layout}`}
      >
        {/* Dégradé qui apparaît au hover, card flat au repos */}
        <div
          class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
        >
          <div
            class="absolute inset-0 bg-gradient-to-br from-[var(--primary-light)]/20 via-transparent to-[var(--accent)]/20"
          ></div>
        </div>

        <div class="relative z-10 flex h-full flex-col gap-5 p-6 group-hover:border-[var(--accent)]/40 group-hover:shadow-[0_18px_40px_rgba(0,0,0,0.6)] transition-[border-color,box-shadow] duration-300">
          <div class="flex items-start justify-between gap-4">
            <div class="flex items-center gap-4">
              {/* Icône avec légère anim */}
              <div
                class="relative flex h-20 w-20 items-center justify-center overflow-hidden rounded-3xl border border-[var(--border)] bg-[var(--background-tertiary)] transition-transform duration-300 ease-out group-hover:-translate-y-1 group-hover:rotate-3"
              >
                <span class="relative text-4xl transition-transform duration-300 ease-out group-hover:scale-110">
                  {card.icon}
                </span>
              </div>
              {/* Titre + sous-titre animés via variable font */}
              <div class="transition-all duration-300 ease-out group-hover:translate-y-[-2px]">
                <h3 class="card-title text-3xl text-[var(--text-primary)]">
                  {card.title}
                </h3>
                <p class="mt-1 text-xs uppercase tracking-[0.16em] text-[var(--text-secondary)]">
                  {card.id === "ia" ? "IA appliquée & outillage" : "Développement"}
                </p>
              </div>
            </div>
          </div>

          {/* Description animée (taille + couleur) */}
          <p class="card-description text-lg leading-relaxed text-[var(--text-secondary)]">
            {card.description}
          </p>

          <div class="mt-auto">
            <p class="mb-3 text-xs font-medium uppercase tracking-[0.18em] text-[var(--accent)]">
              Technologies
            </p>
            <div class="flex flex-wrap gap-2.5">
              {card.technologies?.map((tech) => (
                <span
                  class="tech-pill inline-flex items-center gap-1.5 rounded-full border border-[var(--border)] bg-[var(--background-tertiary)] px-3 py-1.5 text-sm text-[var(--text-primary)]"
                >
                  <span
                    class="inline-block h-1.5 w-1.5 rounded-full"
                    style="background: radial-gradient(circle at 30% 30%, var(--accent-strong), var(--accent));"
                  ></span>
                  <span class="whitespace-nowrap">{tech.name}</span>
                </span>
              ))}
            </div>
          </div>
        </div>
      </article>
    ))}
  </div>

  <style is:global>
    :root {
      --primary: #624432;
      --primary-light: #866754;
      --accent: #8bb4cc;
      --accent-strong: #a1c8e0;
      --background-primary: #0f0f0f;
      --background-secondary: #1a1a1a;
      --background-tertiary: #242424;
      --text-primary: #e8e8e8;
      --text-secondary: #a0a0a0;
      --border: #2a2a2a;
      --shadow: rgba(0, 0, 0, 0.6);
    }

    [data-bento-card] {
      position: relative;
      isolation: isolate;
      background-color: var(--background-secondary);
    }

    /* Si ta variable font a un axe "wght" standard */
    .card-title {
      /* Poids de base (à adapter à ta plage) */
      font-variation-settings: "wght" 550;
      transition:
        font-variation-settings 220ms ease,
        transform 220ms ease;
    }

    [data-bento-card].group:hover .card-title {
      font-variation-settings: "wght" 750;
      transform: translateY(-2px);
    }

    .card-description {
      font-size: 1.05rem;
      transition:
        font-size 220ms ease,
        color 220ms ease,
        transform 220ms ease;
    }

    [data-bento-card].group:hover .card-description {
      font-size: 1.12rem;
      color: var(--text-primary);
      transform: translateY(-1px);
    }

    .tech-pill {
      transition:
        transform 220ms ease,
        border-color 220ms ease,
        background-color 220ms ease;
    }

    [data-bento-card].group:hover .tech-pill {
      transform: translateY(-2px);
      border-color: rgba(139, 180, 204, 0.6);
      background-color: rgba(36, 36, 36, 0.95);
    }

    /* Optionnel : tu peux aussi animer légèrement le h2 s'il partage la même variable font
    .section-title {
      font-variation-settings: "wght" 650;
      transition: font-variation-settings 240ms ease;
    }

    section:hover .section-title {
      font-variation-settings: "wght" 780;
    }
    */
  </style>
</section>
