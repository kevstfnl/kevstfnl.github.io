---
import { site } from "@/assets/data/site";
import Base from "@/layouts/Base.astro";
---

<Base
	title={`Blog technique TypeScript & IA — ${site.name}`}
	description="Articles et notes de Kevin Stefanelli autour du TypeScript, de l'IA appliquée et des architectures web modernes."
>
	<section class="section container">
		<p class="eyebrow">// Blog</p>
		<h1>Notes TypeScript, IA et architecture web.</h1>
		<p class="page-lead">
			Des retours d'expérience et des explorations techniques arriveront ici au
			fil de la construction du portfolio.
		</p>
	</section>
</Base>
