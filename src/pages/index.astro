---
import { site } from "@/assets/data/site";
import Avatar from "@/components/design/Avatar.astro";
import Base from "@/layouts/Base.astro";
---

<Base
	title={`${site.name} — ${site.role}`}
	description="Développeur TypeScript full-stack spécialisé en IA, j'aide à concevoir des interfaces modernes, des backends robustes et des pipelines RAG utiles."
	image="/og.png"
>
	<section class="container">
		<Avatar />
		<div class="hero-container">
			<div class="hero-text">
				<h1>
					Développement d'applications web rapides, modernes et
					scalables
				</h1>
				<p>
					Je conçois et développe des applications web rapides,
					maintenables et évolutives, adaptées aux besoins métiers et
					aux enjeux de performance.
				</p>
			</div>
			<div class="hero-cta">
				<button class="btn btn-primary">TEST EFFECT</button>
				<button class="btn btn-outline-primary">TEST EFFECT</button>
			</div>
		</div>
	</section>
</Base>
<style>
	section {
		display: flex;
		flex-direction: column;
		gap: 2em;
		height: 100vh;
		justify-content: center;
	}

	.hero-container {
		display: flex;
		flex-direction: column;
		gap: 2rem;
	}

	.hero-cta {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
</style>
