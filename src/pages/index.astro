---
import { site } from "@/assets/data/site";
import HeroSection from "@/components/sections/home/HeroSection.astro";
import ProjectSection from "@/components/sections/home/ProjectSection.astro";
import SkillSection from "@/components/sections/home/SkillSection.astro";
import WhoSection from "@/components/sections/home/WhoSection.astro";
import Base from "@/layouts/Base.astro";
---

<Base
	title={`${site.name} — ${site.role}`}
	description="Développeur TypeScript full-stack spécialisé en IA, j'aide à concevoir des interfaces modernes, des backends robustes et des pipelines RAG utiles."
	image="/og.png"
>
	<div class="main">
		<HeroSection />
		<WhoSection />
		<SkillSection />
		<ProjectSection />
	</div>
</Base>

<style>
	.main {
		display: flex;
		flex-direction: column;
		gap: 10em;
	}
</style>
