---
import { site } from "@/assets/data/site";
import Avatar from "@/components/design/Avatar.astro";
import Base from "@/layouts/Base.astro";
---

<Base
	title={`${site.name} — ${site.role}`}
	description="Développeur TypeScript full-stack spécialisé en IA, j'aide à concevoir des interfaces modernes, des backends robustes et des pipelines RAG utiles."
	image="/og.png"
>
	<section class="section container">
		<p class="eyebrow">// Portfolio</p>
		<h1>{site.name}, développeur TypeScript full-stack & IA.</h1>
		<p class="page-lead">{site.availability}</p>
	</section>
	<Avatar />
</Base>
