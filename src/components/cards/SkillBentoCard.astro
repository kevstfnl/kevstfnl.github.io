---
interface Props {
	category: string;
	description: string;
	stacks: string[];
	size?: "default" | "wide";
}

const { category, description, stacks, size = "default" } = Astro.props;
---

<article class:list={["skill-card", `skill-card--${size}`]}>
	<div class="skill-card__header">
		<h3>{category}</h3>
	</div>

	<p class="skill-card__description">{description}</p>

	<ul class="skill-card__tags" aria-label={`Stacks ${category}`}>
		{stacks.map((stack) => <li>{stack}</li>)}
	</ul>
</article>

<style>
	.skill-card {
		display: grid;
		grid-template-rows: auto 1fr auto;
		gap: 0;
		min-inline-size: 0;
		min-block-size: 100%;
		border: var(--border-size-sm) solid
			color-mix(in oklch, var(--color-border) 88%, transparent);
		border-radius: var(--radius-lg);
		background: var(--color-surface);
		overflow: hidden;
		transition:
			transform var(--transition-card-duration) var(--transition-card-timing-function),
			border-color var(--transition-card-duration) ease,
			background-color var(--transition-card-duration) ease;
	}

	.skill-card--wide {
		grid-template-rows: auto 1fr auto;
	}

	.skill-card:hover {
		transform: translateY(-0.12rem);
		border-color: color-mix(
			in oklch,
			var(--color-primary) 26%,
			var(--color-border)
		);
		background: color-mix(in oklch, var(--color-surface) 94%, var(--color-primary));
	}

	.skill-card__header {
		padding: var(--space-lg) var(--space-xl);
		border-bottom: var(--border-size-sm) solid var(--color-border);
	}

	.skill-card h3 {
		font-size: clamp(1.28rem, 1.08rem + 0.9vw, 1.95rem);
		max-inline-size: 14ch;
	}

	.skill-card__description {
		max-inline-size: 42ch;
		padding: var(--space-lg) var(--space-xl) var(--space-xl);
		line-height: 1.72;
		align-self: stretch;
	}

	.skill-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: var(--space-xs);
		align-content: start;
		padding: 0 var(--space-xl) var(--space-xl);
		margin: 0;
		list-style: none;
	}

	.skill-card__tags li {
		display: inline-flex;
		place-items: center;
		align-items: center;
		justify-content: center;
		min-block-size: 2.25rem;
		padding-inline: 0.8rem;
		border: var(--border-size-sm) solid
			color-mix(in oklch, var(--color-border) 88%, transparent);
		border-radius: var(--radius-md);
		background: var(--color-surface-alt);
		color: var(--color-text);
		font-size: 0.84rem;
		font-weight: 700;
		line-height: 1;
		text-align: center;
		white-space: nowrap;
	}

	.skill-card--wide .skill-card__description {
		max-inline-size: 50ch;
	}

	@media (min-width: 48rem) {
		.skill-card__header {
			padding: var(--space-xl) var(--space-xl) var(--space-lg);
		}

		.skill-card__description {
			padding-block-start: var(--space-xl);
		}

		.skill-card--wide {
			grid-column: span 2;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.skill-card,
		.skill-card:hover {
			transform: none;
		}
	}
</style>
