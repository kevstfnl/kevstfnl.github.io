---
interface Props {
	index: number;
	category: string;
	description: string;
	stacks: string[];
	size?: "default" | "wide";
}

const { index, category, description, stacks, size = "default" } = Astro.props;
---

<article class:list={["skill-card", `skill-card--${size}`]}>
	<div class="skill-card__header">
		<h3>{category}</h3>
	</div>

	<p class="skill-card__description">{description}</p>

	<ul class="skill-card__tags" aria-label={`Stacks ${category}`}>
		{stacks.map((stack) => <li>{stack}</li>)}
	</ul>
</article>

<style>
	.skill-card {
		position: relative;
		display: grid;
		gap: 1.25rem;
		min-inline-size: 0;
		padding: 1.35rem;
		border-radius: 1.5rem;
		background: linear-gradient(
			160deg,
			color-mix(
				in oklch,
				var(--color-surface-alt) 92%,
				var(--color-surface)
			),
			color-mix(in oklch, var(--color-surface-alt) 74%, var(--color-bg))
		);
		box-shadow: 0 1rem 2rem rgb(17 12 9 / 0.04);
		overflow: hidden;
		transition:
			transform 240ms cubic-bezier(0.22, 1, 0.36, 1),
			border-color 240ms ease,
			box-shadow 240ms ease;
	}

	.skill-card:hover {
		transform: translateY(-0.18rem);
		border-color: color-mix(
			in oklch,
			var(--color-primary) 22%,
			var(--color-border)
		);
		box-shadow: 0 1.25rem 2.5rem rgb(17 12 9 / 0.07);
	}

	.skill-card__header {
		display: grid;
		gap: 0.75rem;
	}

	.skill-card__index {
		font-size: 0.78rem;
		font-weight: 800;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--color-primary);
	}

	.skill-card h3 {
		font-size: clamp(1.2rem, 1.08rem + 0.72vw, 1.8rem);
	}

	.skill-card__description {
		max-inline-size: 42ch;
	}

	.skill-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		padding: 0;
		margin: 0;
		list-style: none;
	}

	.skill-card__tags li {
		display: inline-flex;
		align-items: center;
		min-block-size: 2.1rem;
		padding: 0.45rem 0.8rem;
		border: 0.0625rem solid
			color-mix(in oklch, var(--color-primary) 14%, var(--color-border));
		border-radius: 999px;
		background: color-mix(
			in oklch,
			var(--color-primary) 7%,
			var(--color-surface)
		);
		color: var(--color-text);
		font-size: 0.92rem;
		font-weight: 700;
		line-height: 1.2;
	}

	@media (min-width: 48rem) {
		.skill-card {
			padding: 1.5rem;
		}

		.skill-card--wide {
			grid-column: span 2;
		}
	}
</style>
