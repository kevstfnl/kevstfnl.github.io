---
interface Props {
	category: string;
	description: string;
	stacks: string[];
	size?: "default" | "wide";
}

const { category, description, stacks, size = "default" } = Astro.props;
---

<article class:list={["skill-card", `skill-card--${size}`]}>
	<div class="skill-card__header">
		<h3>{category}</h3>
	</div>

	<p class="skill-card__description">{description}</p>

	<ul class="skill-card__tags" aria-label={`Stacks ${category}`}>
		{stacks.map((stack) => <li>{stack}</li>)}
	</ul>
</article>

<style>
	.skill-card {
		position: relative;
		display: grid;
		grid-template-rows: auto 1fr auto;
		gap: var(--space-xl);
		min-inline-size: 0;
		min-block-size: 100%;
		padding: 1.6rem;
		border: var(--border-size-sm) solid
			color-mix(in oklch, var(--color-border) 82%, transparent);
		border-radius: var(--radius-xl);
		background: linear-gradient(
			155deg,
			color-mix(
				in oklch,
				var(--color-surface-alt) 90%,
				var(--color-surface)
			),
			color-mix(in oklch, var(--color-surface-alt) 72%, var(--color-bg))
		);
		box-shadow:
			0 1.1rem 2.2rem rgb(17 12 9 / 0.05),
			var(--shadow-inset-light);
		overflow: hidden;
		transition:
			transform var(--transition-card-duration) var(--transition-card-timing-function),
			border-color var(--transition-card-duration) ease,
			box-shadow var(--transition-card-duration) ease;
	}

	.skill-card::after {
		content: "";
		position: absolute;
		inset: auto -15% -30% auto;
		inline-size: 11rem;
		block-size: 11rem;
		border-radius: var(--radius-pill);
		background: radial-gradient(
			circle,
			color-mix(in oklch, var(--color-primary) 15%, transparent) 0%,
			transparent 68%
		);
		opacity: 0.8;
		pointer-events: none;
	}

	.skill-card--wide {
		gap: 1.65rem;
	}

	.skill-card:hover {
		transform: translateY(-0.18rem);
		border-color: color-mix(
			in oklch,
			var(--color-primary) 22%,
			var(--color-border)
		);
		box-shadow:
			var(--shadow-card-hover),
			var(--shadow-inset-light-strong);
	}

	.skill-card__header {
		display: grid;
		gap: var(--space-md);
		position: relative;
		z-index: 1;
	}

	.skill-card h3 {
		font-size: clamp(1.28rem, 1.08rem + 0.9vw, 1.95rem);
		max-inline-size: 14ch;
	}

	.skill-card__description {
		max-inline-size: 42ch;
		position: relative;
		z-index: 1;
		line-height: 1.72;
		align-self: stretch;
	}

	.skill-card__tags {
		display: flex;
		flex-wrap: wrap;
		gap: 0.65rem;
		align-content: start;
		padding: 0;
		margin: 0;
		list-style: none;
		position: relative;
		z-index: 1;
	}

	.skill-card__tags li {
		display: inline-flex;
		place-items: center;
		align-items: center;
		justify-content: center;
		min-block-size: 2.5rem;
		padding-inline: 0.95rem;
		border: var(--border-size-sm) solid
			color-mix(in oklch, var(--color-primary) 16%, var(--color-border));
		border-radius: var(--radius-lg);
		background: color-mix(
			in oklch,
			var(--color-primary) 8%,
			var(--color-surface)
		);
		color: var(--color-text);
		font-size: 0.88rem;
		font-weight: 700;
		line-height: 1;
		text-align: center;
		white-space: nowrap;
		box-shadow:
			inset 0 var(--border-size-sm) 0 rgb(255 255 255 / 0.12),
			0 0.0625rem 0 rgb(17 12 9 / 0.03);
	}

	.skill-card--wide .skill-card__description {
		max-inline-size: 50ch;
	}

	@media (min-width: 48rem) {
		.skill-card {
			padding: 1.75rem;
		}

		.skill-card--wide {
			grid-column: span 2;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.skill-card,
		.skill-card:hover {
			transform: none;
		}
	}
</style>
