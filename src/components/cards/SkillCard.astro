---
import type { Skill } from "@/assets/datas/skills";
import { Icon } from "astro-icon/components";

const { title, subtitle, description, iconName, technologies, className } =
    Astro.props as Skill;
---

<article
    class={"relative flex flex-col overflow-hidden max-w-full group/skillcard gap-10 bg-background-secondary border border-border p-5 rounded-3xl" +
        (className ? " " + className : "")}
>
    <span class="flex gap-3 items-center">
        <div
            class="bg-background-tertiary grid place-items-center p-4 rounded-xl border border-border"
        >
            <Icon
                size={50}
                name={iconName}
                class="transition-transform duration-500 group-hover/skillcard:scale-110 group-hover/skillcard:rotate-90"
            />
        </div>
        <div>
            <h3
                class="transition-transform group-hover/skillcard:translate-x-1"
            >
                {title}
            </h3>
            <p
                class="tracking-widest uppercase text-accent transition-transform group-hover/skillcard:translate-x-3"
            >
                {subtitle}
            </p>
        </div>
    </span>
    <p class="text-text-secondary flex-1">{description}</p>
    <div class="flex flex-col gap-3">
        <ul class="flex justify-center px-3 gap-2 items-center flex-wrap">
            {
                technologies.map((tech) => (
                    <li class="flex flex-col items-center justify-center h-15 w-15">
                        <Icon size={24} name={tech.iconName} />
                        <p class="text-text-secondary text-center">
                            {tech.label}
                        </p>
                    </li>
                ))
            }
        </ul>
    </div>

    <div
        class="pointer-events-none absolute inset-0 opacity-0 transition-opacity duration-600 group-hover/skillcard:opacity-100"
    >
        <div
            class="absolute inset-0 bg-linear-to-br from-primary-light/20 via-transparent to-accent/20"
        >
        </div>
    </div>
</article>
