---
import { navLinks } from "@/assets/data/site";
---

<aside class="sidebar-shell" id="mobile-sidebar" aria-hidden="true">
	<button
		type="button"
		class="sidebar-backdrop"
		data-close-sidebar
		aria-label="Fermer le menu"
	></button>

	<div class="sidebar" role="dialog" aria-modal="true" aria-label="Navigation mobile">
		<div class="sidebar__header">
			<p class="sidebar__eyebrow">Navigation</p>
			<button
				type="button"
				class="sidebar__close"
				data-close-sidebar
				aria-label="Fermer le menu"
			>
				<span></span>
				<span></span>
			</button>
		</div>

		<nav class="sidebar__nav">
			<ul class="sidebar-container">
				{
					navLinks.map((link) => (
						<li>
							<a href={link.href} data-sidebar-link>{link.label}</a>
						</li>
					))
				}
			</ul>
		</nav>
	</div>
</aside>

<style>
	.sidebar-shell {
		position: fixed;
		inset: 0;
		z-index: 30;
		pointer-events: none;
	}

	.sidebar-backdrop {
		position: absolute;
		inset: 0;
		background: rgb(17 12 9 / 0.24);
		opacity: 0;
		backdrop-filter: blur(0.2rem);
		transition: opacity 260ms ease;
	}

	.sidebar {
		position: absolute;
		top: 0;
		right: 0;
		display: grid;
		grid-template-rows: auto 1fr;
		gap: 2rem;
		inline-size: min(20rem, calc(100vw - 1rem));
		block-size: 100dvh;
		padding: 1rem;
		background: linear-gradient(
			160deg,
			color-mix(in oklch, var(--color-surface) 92%, var(--color-bg)),
			color-mix(in oklch, var(--color-surface-alt) 88%, var(--color-bg))
		);
		border-inline-start: 0.0625rem solid color-mix(in oklch, var(--color-border) 80%, transparent);
		box-shadow: -1.5rem 0 3rem rgb(17 12 9 / 0.14);
		transform: translateX(calc(100% + 5rem));
		transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
	}

	.sidebar__header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		padding-block-end: 0.5rem;
		border-block-end: 0.0625rem solid color-mix(in oklch, var(--color-border) 70%, transparent);
	}

	.sidebar__eyebrow {
		font-size: 0.82rem;
		font-weight: 800;
		letter-spacing: 0.08em;
		text-transform: uppercase;
		color: var(--color-text-muted);
	}

	.sidebar__close {
		position: relative;
		display: inline-grid;
		place-items: center;
		inline-size: 2.75rem;
		block-size: 2.75rem;
		padding: 0;
		border-radius: 999px;
		background: color-mix(in oklch, var(--color-surface) 88%, var(--color-bg));
		box-shadow: 0 0.75rem 1.5rem rgb(17 12 9 / 0.08);
		color: var(--color-text);
		transition: transform 220ms ease, box-shadow 220ms ease;

		&:hover,
		&:focus-visible {
			transform: translateY(-0.0625rem);
			box-shadow: 0 1rem 1.75rem rgb(17 12 9 / 0.12);
		}

		&:focus-visible {
			outline: 0.1875rem solid color-mix(in oklch, var(--color-primary) 52%, white);
			outline-offset: 0.1875rem;
		}

		span {
			position: absolute;
			inline-size: 1.05rem;
			block-size: 0.125rem;
			border-radius: 999px;
			background: currentColor;

			&:first-child {
				transform: rotate(45deg);
			}

			&:last-child {
				transform: rotate(-45deg);
			}
		}
	}

	.sidebar__nav {
		min-block-size: 0;
	}

	.sidebar-container {
		display: grid;
		align-content: start;
		gap: 0.45rem;
		padding: 0;
		list-style: none;
	}

	.sidebar-container a {
		display: flex;
		align-items: center;
		min-block-size: 3.75rem;
		padding-inline: 1rem;
		border-radius: 0.95rem;
		background: transparent;
		font-size: clamp(1.05rem, 0.98rem + 0.35vw, 1.2rem);
		font-weight: 800;
		color: var(--color-text);
		transition:
			transform 240ms cubic-bezier(0.22, 1, 0.36, 1),
			background-color 240ms ease,
			color 240ms ease;

		&:hover,
		&:focus-visible {
			transform: translateX(0.35rem);
			background: color-mix(in oklch, var(--color-primary) 10%, transparent);
			color: var(--color-primary);
		}

		&:focus-visible {
			outline: 0.1875rem solid color-mix(in oklch, var(--color-primary) 52%, white);
			outline-offset: 0.125rem;
		}
	}

	:global(body[data-sidebar-open="true"]) .sidebar-shell {
		pointer-events: auto;
	}

	:global(body[data-sidebar-open="true"]) {
		overflow: hidden;
	}

	:global(body[data-sidebar-open="true"]) .sidebar-backdrop {
		opacity: 1;
	}

	:global(body[data-sidebar-open="true"]) .sidebar {
		transform: translateX(0);
	}

	@media (min-width: 48rem) {
		.sidebar-shell {
			display: none;
		}
	}
</style>
