<script>
    const svg = document.getElementById("avatar-light");
    const pupils = svg ? Array.from(svg.querySelectorAll(".eye")) : [];

    let mouseX = 0;
    let mouseY = 0;
    let mouseIn = false;
    let rafId = null;

    const resetEyes = () => {
        pupils.forEach((pupil) =>
            pupil.setAttribute("transform", "translate(0, 0)"),
        );
    };

    const updateEyes = () => {
        if (!mouseIn) {
            resetEyes();
            rafId = requestAnimationFrame(updateEyes);
            return;
        }

        const box = svg?.getBoundingClientRect();
        if (!box) {
            rafId = requestAnimationFrame(updateEyes);
            return;
        }
        const centerX = box.left + box.width / 2;
        const centerY = box.top + box.height / 2;

        const dx = mouseX - centerX;
        const dy = mouseY - centerY;
        const distance = Math.hypot(dx, dy);

        const threshold = 50;
        const maxOffsetX = 6;
        const maxOffsetY = 4;

        if (distance < threshold) {
            resetEyes();
        } else {
            const angle = Math.atan2(dy, dx);
            const offsetX = Math.cos(angle) * maxOffsetX;
            const offsetY = Math.sin(angle) * maxOffsetY;

            pupils.forEach((pupil) =>
                pupil.setAttribute(
                    "transform",
                    `translate(${offsetX.toFixed(1)}, ${offsetY.toFixed(1)})`,
                ),
            );
        }

        rafId = requestAnimationFrame(updateEyes);
    };

    const handleMouseMove = (event) => {
        mouseX = event.clientX;
        mouseY = event.clientY;
        mouseIn = true;
    };

    const handleMouseLeave = () => {
        mouseIn = false;
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                if (!rafId) {
                    rafId = requestAnimationFrame(updateEyes);
                }
                window.addEventListener("pointermove", handleMouseMove);
                window.addEventListener("pointerleave", handleMouseLeave);
            } else {
                resetEyes();
                if (rafId) {
                    cancelAnimationFrame(rafId);
                    rafId = null;
                }
                window.removeEventListener("pointermove", handleMouseMove);
                window.removeEventListener("pointerleave", handleMouseLeave);
            }
        });
    });

    if (svg) {
        observer.observe(svg);
    }
</script>
