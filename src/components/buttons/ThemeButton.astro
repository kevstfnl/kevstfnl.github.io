<button type="button" data-toggle-theme aria-label="Changer de theme" title="Changer de theme">
	<svg viewBox="0 0 32 32" aria-hidden="true">
		<defs>
			<mask id="theme-toggle-mask" maskUnits="userSpaceOnUse">
				<rect x="0" y="0" width="32" height="32" fill="white"></rect>
				<circle class="theme-toggle__mask-cutout" cx="19.5" cy="12.5" r="7"></circle>
			</mask>
		</defs>

		<g class="theme-toggle__rays">
			<path d="M16 3.25V7"></path>
			<path d="M16 25V28.75"></path>
			<path d="M3.25 16H7"></path>
			<path d="M25 16H28.75"></path>
			<path d="M6.98 6.98L9.64 9.64"></path>
			<path d="M22.36 22.36L25.02 25.02"></path>
			<path d="M6.98 25.02L9.64 22.36"></path>
			<path d="M22.36 9.64L25.02 6.98"></path>
		</g>

		<circle class="theme-toggle__orb" cx="16" cy="16" r="7.5" mask="url(#theme-toggle-mask)"></circle>
	</svg>
</button>

<style>
	button[data-toggle-theme] {
		--theme-toggle-size: 3rem;
		--theme-toggle-icon-size: 3rem;
		--theme-toggle-transition: var(--theme-change-duration) cubic-bezier(0.22, 1, 0.36, 1);
		--theme-toggle-rays-delay: calc(var(--theme-change-duration) * 0.08);
		--theme-toggle-color-delay: calc(var(--theme-change-duration) * 0.24);
		--theme-toggle-mask-delay: calc(var(--theme-change-duration) * 0.42);
		--theme-toggle-sun: rgb(203, 164, 45);
		--theme-toggle-sun-soft: rgb(225, 206, 129);
		--theme-toggle-moon: rgb(241 245 249);
		--theme-toggle-bg: transparent;

		display: grid;
		place-items: center;
		height: var(--theme-toggle-size);
		width: var(--theme-toggle-size);
		padding: 0;
		background: var(--theme-toggle-bg);
		border-radius: 100%;
		transition: background-color 250ms ease, transform 320ms;

		&:hover svg,
		&:focus-visible svg {
			transform: scale(1.1);
		}

		&:focus-visible {
			outline: 0.1875rem solid color-mix(in oklch, var(--color-primary) 52%, white);
			outline-offset: 0.1875rem;
		}

		&:active svg {
			transform: scale(1);
		}

		svg {
			overflow: visible;
			height: var(--theme-toggle-icon-size);
			width: var(--theme-toggle-icon-size);
			transition: transform 250ms cubic-bezier(0.22, 1, 0.36, 1);
		}
	}

	.theme-toggle__orb {
		fill: var(--theme-toggle-sun);
		transform-origin: 50% 50%;
		transition:
			fill calc(var(--theme-change-duration) * 0.48) ease var(--theme-toggle-color-delay),
			transform calc(var(--theme-change-duration) * 0.52) cubic-bezier(0.22, 1, 0.36, 1)
				var(--theme-toggle-color-delay);
	}

	.theme-toggle__rays {
		transform-origin: 50% 50%;
		transition: transform calc(var(--theme-change-duration) * 0.55) cubic-bezier(0.22, 1, 0.36, 1)
			var(--theme-toggle-rays-delay);
	}

	.theme-toggle__rays path {
		fill: none;
		stroke: var(--theme-toggle-sun);
		stroke-linecap: round;
		stroke-width: 2;
		transform-box: fill-box;
		transform-origin: center;
		transition:
			stroke calc(var(--theme-change-duration) * 0.3) ease var(--theme-toggle-color-delay),
			transform calc(var(--theme-change-duration) * 0.55) cubic-bezier(0.4, 0, 0.2, 1)
				var(--theme-toggle-rays-delay);
	}

	.theme-toggle__mask-cutout {
		fill: black;
		transform-box: fill-box;
		transform-origin: center;
		transform: translate(8px, -8px) scale(0.35);
		transition: transform calc(var(--theme-change-duration) * 0.5) cubic-bezier(0.22, 1, 0.36, 1)
			var(--theme-toggle-mask-delay);
	}

	:global(html[theme="dark"]) button[data-toggle-theme] {
		--theme-toggle-bg: transparent;

		&:hover svg,
		&:focus-visible svg {
			transform: rotate(-10deg) scale(1.04);
		}
	}

	:global(html[theme="dark"]) .theme-toggle__orb {
		fill: var(--theme-toggle-moon);
		transform: scale(1.12);
	}

	:global(html[theme="dark"]) .theme-toggle__rays {
		transform: scale(0.78) rotate(-10deg);
	}

	:global(html[theme="dark"]) .theme-toggle__rays path {
		stroke: var(--theme-toggle-moon);
		transform: scale(0.08);
	}

	:global(html[theme="dark"]) .theme-toggle__mask-cutout {
		transform: translate(-1px, 1px) scale(0.92);
	}
</style>
