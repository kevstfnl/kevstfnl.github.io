---
import { languages, skills } from "@/assets/data/site";
import SkillBentoCard from "@/components/cards/SkillBentoCard.astro";

const featuredCategories = new Set(["Frontend", "IA"]);
const languageTracks = Array.from({ length: 4 }, () => languages);
---

<section id="skills">
    <div class="skills-shell container xl">
        <div class="skill-title">
            <p class="skill-label">Expertise</p>
            <h2>Une stack complète pour concevoir, livrer et faire évoluer.</h2>
            <p>
                Du frontend jusqu'aux usages IA, j'interviens sur l'ensemble de
                la chaine pour produire des applications lisibles, utiles et
                durables.
            </p>
        </div>

        <div class="skill-grid">
            {
                skills.map((skill) => (
                    <SkillBentoCard
                        category={skill.category}
                        description={skill.description}
                        stacks={skill.stacks}
                        size={
                            featuredCategories.has(skill.category)
                                ? "wide"
                                : "default"
                        }
                    />
                ))
            }
        </div>

        <div class="languages-block" aria-labelledby="languages-title">
            <div class="languages-marquee">
                <div class="languages-rail">
                    {
                        languageTracks.map((track, trackIndex) => (
                            <ul
                                class="languages-track"
                                aria-hidden={
                                    trackIndex > 0 ? "true" : undefined
                                }
                            >
                                {track.map((language) => (
                                    <li>
                                        <span>{language}</span>
                                    </li>
                                ))}
                            </ul>
                        ))
                    }
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    section {
        display: flex;
        flex-direction: column;
        gap: var(--space-4xl);
        padding-block: var(--section-padding-block);
    }

    .skills-shell {
        display: grid;
        gap: var(--space-3xl);
    }

    .skill-title {
        display: grid;
        gap: var(--space-md);
        text-align: center;
        justify-items: center;
        margin-inline: auto;
    }

    .skill-label {
        font-size: var(--label-font-size);
        font-weight: var(--label-font-weight);
        letter-spacing: var(--label-letter-spacing);
        text-transform: var(--label-text-transform);
        color: var(--color-primary);
    }

    .skill-title p:last-child {
        max-inline-size: 42rem;
    }

    .skill-grid {
        display: grid;
        gap: var(--space-md);
        grid-template-columns: minmax(0, 1fr);
    }

    .languages-block {
        display: grid;
        gap: var(--space-lg);
        padding-block-start: var(--space-xs);
    }

    .languages-marquee {
        --languages-gap: 0.85rem;
        position: relative;
        overflow: hidden;
        padding-block: var(--space-2xs);
        mask-image: linear-gradient(
            90deg,
            transparent,
            black 12%,
            black 88%,
            transparent
        );
    }

    .languages-rail {
        display: flex;
        align-items: center;
        flex-wrap: nowrap;
        width: max-content;
        gap: 0;
        animation: languages-marquee 26s linear infinite;
        will-change: transform;
    }

    .languages-track {
        display: flex;
        align-items: center;
        gap: var(--languages-gap);
        padding: 0;
        margin: 0;
        margin-inline-end: var(--languages-gap);
        list-style: none;
        flex: 0 0 auto;
    }

    .languages-track li {
        flex: 0 0 auto;
    }

    .languages-track span {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-block-size: 3rem;
        padding-inline: 1.1rem;
        border: var(--border-size-sm) solid
            color-mix(in oklch, var(--color-primary) 16%, var(--color-border));
        border-radius: var(--radius-pill);
        background: linear-gradient(
            180deg,
            color-mix(in oklch, var(--color-surface) 92%, white),
            color-mix(in oklch, var(--color-surface-alt) 82%, var(--color-bg))
        );
        box-shadow:
            var(--shadow-inset-light),
            var(--shadow-chip);
        color: var(--color-text);
        font-size: 0.95rem;
        font-weight: 800;
        letter-spacing: 0.01em;
        white-space: nowrap;
    }

    @keyframes languages-marquee {
        from {
            transform: translateX(0);
        }

        to {
            transform: translateX(-25%);
        }
    }

    @media (min-width: 48rem) {
        section {
            padding-block: var(--section-padding-block-lg);
        }

        .skill-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: var(--space-lg);
        }

        .languages-block {
            gap: var(--space-xl);
        }

        .languages-marquee {
            --languages-gap: 1rem;
        }

        .languages-track span {
            min-block-size: 3.2rem;
            padding-inline: 1.25rem;
        }
    }

    @media (min-width: 64rem) {
        .skill-grid {
            grid-template-columns: repeat(4, minmax(0, 1fr));
            auto-rows: 1fr;
            align-items: stretch;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .languages-rail {
            animation: none;
        }

        .languages-marquee {
            overflow-x: auto;
            mask-image: none;
        }
    }
</style>
