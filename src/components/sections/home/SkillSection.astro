---
import { languages, skills } from "@/assets/data/site";
import SkillBentoCard from "@/components/cards/SkillBentoCard.astro";

const featuredCategories = new Set(["Frontend", "IA"]);
const languageTracks = Array.from({ length: 4 }, () => languages);
---

<section id="skills">
    <div class="skills-shell container xl">
        <div class="skill-title">
            <p class="skill-label">Expertise</p>
            <h2>Une stack complète pour concevoir, livrer et faire évoluer.</h2>
            <p>
                Du frontend jusqu'aux usages IA, j'interviens sur l'ensemble de
                la chaine pour produire des applications lisibles, utiles et
                durables.
            </p>
        </div>

        <div class="skill-grid">
            {
                skills.map((skill) => (
                    <SkillBentoCard
                        category={skill.category}
                        description={skill.description}
                        stacks={skill.stacks}
                        size={
                            featuredCategories.has(skill.category)
                                ? "wide"
                                : "default"
                        }
                    />
                ))
            }
        </div>

        <div class="languages-block" aria-labelledby="languages-title">
            <div class="languages-marquee">
                <div class="languages-rail">
                    {
                        languageTracks.map((track, trackIndex) => (
                            <ul
                                class="languages-track"
                                aria-hidden={
                                    trackIndex > 0 ? "true" : undefined
                                }
							>
								{track.map((language) => (
									<li>
										<span
											style={`--language-color: ${language.color}; --language-text-color: ${language.textColor};`}
										>
											<span class="language-mark" aria-hidden="true">
												{language.mark}
											</span>
											<span>{language.name}</span>
										</span>
									</li>
								))}
							</ul>
						))
					}
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    section {
        display: flex;
        flex-direction: column;
        gap: var(--space-4xl);
        padding-block: var(--section-padding-block);
    }

    .skills-shell {
        display: grid;
        gap: var(--space-3xl);
    }

    .skill-title {
        display: grid;
        gap: var(--space-md);
        text-align: center;
        justify-items: center;
        margin-inline: auto;
    }

    .skill-label {
        font-size: var(--label-font-size);
        font-weight: var(--label-font-weight);
        letter-spacing: var(--label-letter-spacing);
        text-transform: var(--label-text-transform);
        color: var(--color-primary);
    }

    .skill-title p:last-child {
        max-inline-size: 42rem;
    }

    .skill-grid {
        display: grid;
        gap: var(--space-md);
        grid-template-columns: minmax(0, 1fr);
    }

    .languages-block {
        display: grid;
        gap: var(--space-lg);
        padding-block-start: var(--space-xs);
    }

	.languages-marquee {
		--languages-gap: 0.85rem;
		position: relative;
		overflow: hidden;
		padding-block: var(--space-sm);
		mask-image: linear-gradient(
			90deg,
			transparent,
			black 14%,
			black 86%,
			transparent
		);
	}

    .languages-rail {
        display: flex;
        align-items: center;
        flex-wrap: nowrap;
        width: max-content;
        gap: 0;
        animation: languages-marquee 26s linear infinite;
        will-change: transform;
    }

    .languages-track {
        display: flex;
        align-items: center;
        gap: var(--languages-gap);
        padding: 0;
        margin: 0;
        margin-inline-end: var(--languages-gap);
        list-style: none;
        flex: 0 0 auto;
    }

    .languages-track li {
        flex: 0 0 auto;
    }

	.languages-track > li > span {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: var(--space-xs);
		min-block-size: 2.75rem;
		padding-inline: var(--space-sm) var(--space-md);
		border-radius: var(--radius-pill);
		color: var(--color-text);
		font-size: 0.9rem;
		font-weight: 800;
		letter-spacing: 0.01em;
		white-space: nowrap;
	}

	.languages-track .language-mark {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0;
		min-inline-size: 1.55rem;
		block-size: 1.55rem;
		padding-inline: 0.28rem;
		border-radius: var(--radius-md);
		background: var(--language-color);
		color: var(--language-text-color);
		font-size: 0.58rem;
		font-weight: 1000;
		letter-spacing: 0;
		line-height: 1;
		white-space: nowrap;
	}

    @keyframes languages-marquee {
        from {
            transform: translateX(0);
        }

        to {
            transform: translateX(-25%);
        }
    }

    @media (min-width: 48rem) {
        section {
            padding-block: var(--section-padding-block-lg);
        }

        .skill-grid {
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: var(--space-lg);
        }

        .languages-block {
            gap: var(--space-xl);
        }

        .languages-marquee {
            --languages-gap: 1rem;
        }

		.languages-track > li > span {
			min-block-size: 2.9rem;
			padding-inline: var(--space-sm) var(--space-lg);
		}
	}

    @media (min-width: 64rem) {
        .skill-grid {
            grid-template-columns: repeat(4, minmax(0, 1fr));
            auto-rows: 1fr;
            align-items: stretch;
        }
    }

    @media (prefers-reduced-motion: reduce) {
        .languages-rail {
            animation: none;
        }

        .languages-marquee {
            overflow-x: auto;
            mask-image: none;
        }
    }
</style>
