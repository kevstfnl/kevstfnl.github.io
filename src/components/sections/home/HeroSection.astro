---
import Avatar from "@/components/design/Avatar.astro";
---

<section class="hero-section">
    <div class="hero-grid container xl">
        <div class="avatar">
            <Avatar />
        </div>

        <div class="hero-container">
            <div class="hero-text">
                <h1>Développement d'applications web modernes et scalables</h1>
                <p>
                    Je conçois et développe des applications web performante,
                    maintenables et évolutives, adaptées à vos besoins métiers
                    et vos enjeux.
                </p>
            </div>
            <div class="hero-cta">
                <button class="btn btn-primary">Voir mes projets</button>
                <button class="btn btn-outline-primary">Me contacter</button>
            </div>
        </div>
    </div>

	<a
		class="scroll-indicator"
		href="#about"
		aria-label="Le site est encore en construction... Scroller vers la section A propos"
	>
        <p class="warning">Le site est encore en construction...</p>
        <span class="scroll-indicator__mouse" aria-hidden="true">
            <span class="scroll-indicator__wheel"></span>
        </span>
        <span class="scroll-indicator__arrow" aria-hidden="true"></span>
    </a>
</section>

<style>
    .warning {
        text-align: center;
        color: var(--color-text);
        letter-spacing: -0.02ch;
        line-height: 0.7;
        padding-bottom: var(--space-md);

    }

    .hero-section {
        position: relative;
        min-height: 100dvh;
    }

	.hero-grid {
		display: grid;
		gap: var(--space-xl);
		grid-template-columns: minmax(0, 1fr);
		align-items: center;
		padding-top: var(--space-4xl);
		padding-bottom: var(--space-xl);
	}

	.avatar {
		justify-self: center;
		inline-size: min(12.5rem, 52vw);
		min-inline-size: 0;
	}

	.hero-container {
		display: grid;
		gap: var(--space-xl);
		min-inline-size: 0;
		inline-size: 100%;
        max-inline-size: 38rem;
    }

    .hero-text {
        display: grid;
        gap: var(--space-md);
    }

    .hero-text h1 {
        font-size: clamp(1.85rem, 1.45rem + 3.1vw, 4.5rem);
    }

    .hero-text p {
        max-inline-size: 36ch;
    }

    .hero-cta {
        display: flex;
        flex-direction: column;
        gap: var(--space-xs);
    }

	.scroll-indicator {
		position: static;
		width: max-content;
		margin: var(--space-xl) auto 0;
		display: grid;
		justify-items: center;
        color: var(--color-primary);
        text-decoration: none;
        z-index: 2;
		transition:
			transform var(--transition-fast-duration) ease,
            opacity var(--transition-fast-duration) ease;
        opacity: 0.95;
    }

	.scroll-indicator:hover {
		transform: translateY(0.2rem);
	}

    .scroll-indicator__mouse {
        display: grid;
        justify-items: center;
        inline-size: 1.6rem;
        block-size: 2.6rem;
        padding-top: 0.35rem;
        border: var(--border-size-md) solid
            color-mix(in srgb, var(--color-primary) 75%, transparent);
        border-radius: var(--radius-pill);
        background: color-mix(in srgb, var(--color-bg) 72%, transparent);
        box-shadow: 0 0 0 1px
            color-mix(in srgb, var(--color-bg) 35%, transparent);
    }

    .scroll-indicator__wheel {
        inline-size: 0.28rem;
        block-size: 0.65rem;
        border-radius: var(--radius-pill);
        background: currentColor;
        animation: scroll-wheel 1.4s ease-in-out infinite;
    }

	.scroll-indicator__arrow {
		inline-size: 0.8rem;
		block-size: 0.8rem;
        border-right: var(--border-size-md) solid currentColor;
        border-bottom: var(--border-size-md) solid currentColor;
        transform: rotate(45deg);
		animation: scroll-arrow 1.4s ease-in-out infinite;
	}

	@media (min-height: 48rem) and (max-width: 47.999rem) {
		.hero-grid {
			min-height: calc(100dvh - 9rem);
		}
	}

	@keyframes scroll-wheel {
        0% {
            transform: translateY(0);
            opacity: 0;
        }

        20% {
            opacity: 1;
        }

        100% {
            transform: translateY(0.7rem);
            opacity: 0;
        }
    }

    @keyframes scroll-arrow {
        0%,
        100% {
            transform: translateY(0) rotate(45deg);
            opacity: 0.55;
        }

        50% {
            transform: translateY(0.35rem) rotate(45deg);
            opacity: 1;
        }
    }

    @media (prefers-reduced-motion: reduce) {
		.scroll-indicator,
		.scroll-indicator:hover {
			transform: none;
		}

        .scroll-indicator__wheel,
        .scroll-indicator__arrow {
            animation: none;
        }
    }

	@media (min-width: 48rem) {
		.hero-grid {
			gap: var(--space-3xl);
			min-height: 90dvh;
		}

		.scroll-indicator {
			position: absolute;
			left: 50%;
			bottom: var(--space-2xl);
			margin: 0;
			transform: translateX(-50%);
		}

		.scroll-indicator:hover {
			transform: translateX(-50%) translateY(0.2rem);
		}

		.hero-grid {
			grid-template-columns: minmax(0, 0.95fr) minmax(19rem, 24rem);
            min-height: min(100dvh, 56rem);
        }

		.avatar {
			order: 2;
			justify-self: end;
            inline-size: clamp(22rem, 45vw, 40rem);
            margin-inline-end: clamp(0.5rem, 1.5vw, 1.25rem);
        }

        .hero-container {
            order: 1;
            justify-self: start;
            max-inline-size: 34rem;
        }

        .hero-cta {
            flex-direction: row;
            flex-wrap: wrap;
        }
    }

	@media (min-width: 64rem) {
		.hero-grid {
			grid-template-columns: minmax(0, 0.92fr) minmax(22rem, 27rem);
            gap: clamp(1.25rem, 3vw, 2.5rem);
        }

        .avatar {
            inline-size: clamp(26rem, 40vw, 36rem);
            margin-inline-end: clamp(0.75rem, 2vw, 1.5rem);
        }

		.hero-text h1 {
			font-size: clamp(2rem, 1.5rem + 2.8vw, 4.75rem);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.scroll-indicator,
		.scroll-indicator:hover {
			transform: none;
		}
	}

	@media (min-width: 48rem) and (prefers-reduced-motion: reduce) {
		.scroll-indicator,
		.scroll-indicator:hover {
			transform: translateX(-50%);
		}
	}
</style>
